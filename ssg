#!/bin/sh

SRCDIR=""
DESTDIR=""
STATICDIR=""
TEMPLATE=""

build() {
	rm -rf ${DESTDIR}/
	mkdir ${DESTDIR}/
	for f in $(find ${SRCDIR}/ -type f,l); do
		if [ "${f}" = ${TEMPLATE} ]; then
			continue
		fi
		path=${f#${SRCDIR}}
		base=${path%.*}
		out="${DESTDIR}${base}.html"
		mkdir -p $(dirname ${out})
		pandoc \
			-V date="$(date +'%B %d, %Y')" \
			-standalone \
			--template=${TEMPLATE} \
			--to=html \
			${f} > ${out}
	done
	cp -a ${STATICDIR}/. ${DESTDIR}/
	echo "build complete"
}

usageMsg() {
	echo "usage: ssg [-b]"
	echo "help: man ssg"
	exit 1
}

error() {
	echo "error: ${1}"
	shift
	for msg in "$@"; do
		echo "${msg}"
	done
	echo "help: man ssg"
	exit 1;
}

checkConfig() {
	if [ -z "${SRCDIR}" ]; then
		error "missing SRCDIR in config" ${conf}
	elif [ -z "${DESTDIR}" ]; then
		error "missing DESTDIR in config" ${conf}
	elif [ -z "${STATICDIR}" ]; then
		error "missing STATICDIR in config" ${conf}
	elif [ -z "${TEMPLATE}" ]; then
		error "missing TEMPLATE in config" ${conf}
	elif [ ! -d ${SRCDIR} ]; then
		error "directory not found '${SRCDIR}'" ${conf}
	elif [ ! -d ${DESTDIR} ]; then
		error "directory not found '${DESTDIR}'" ${conf}
	elif [ ! -d ${STATICDIR} ]; then
		error "directory not found '${STATICDIR}'" ${conf}
	elif [ ! -f ${TEMPLATE} ]; then
		error "file not found '${TEMPLATE}'" ${conf}
	fi
}

set -eu
conf="${PWD}/ssg.conf"
if [ -f ${conf} ]; then
	. ${conf}
	checkConfig
else
	error "config file not found '${conf}'"
fi
if [ $# -eq 0 ]; then
	usageMsg
fi
if [ ${1} = "-b" ]; then
	build
else
	usageMsg
fi