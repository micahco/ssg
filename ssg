#!/bin/sh

SRCDIR=""
DESTDIR=""
STATICDIR=""
TEMPLATE=""
BLOGDIR=""
BLOGTITLE=""

buildArg=false
blogArg=false
devArg=false

build() {
	if [ ! -d ${SRCDIR} ]; then
		configPathErr ${SRCDIR}
	elif [ ! -d ${DESTDIR} ]; then
		configPathErr ${DESTDIR}
	elif [ ! -d ${STATICDIR} ]; then
		configPathErr ${STATICDIR}
	elif [ ! -f ${TEMPLATE} ]; then
		configPathErr ${TEMPLATE}
	fi
	rm -rf ${DESTDIR}/
	mkdir ${DESTDIR}/
	for f in $(find ${SRCDIR}/ -type f,l); do
		if [ "${f}" = ${TEMPLATE} ]; then
			continue
		fi
		path=${f#${SRCDIR}}
		base=${path%.*}
		out="${DESTDIR}${base}.html"
		mkdir -p $(dirname ${out})
		pandoc \
			-standalone \
			--template=${TEMPLATE} \
			--to=html \
			${f} > ${out}
	done
	cp -a ${STATICDIR}/. ${DESTDIR}/
	echo "build complete"
}

blog() {
	if [ ! -d ${BLOGDIR} ]; then
		pathErr ${BLOGDIR}
	fi
	index="${BLOGDIR}/index.md"
	if [ -f ${index} ]; then
		rm ${index}
	fi
	touch ${index}
	title=$(echo ${BLOGTITLE} | sed -e 's/#//g' -e 's/ *$//g')
	echo "---" >> ${index}
	echo "title: ${title}" >> ${index}
	echo "---" >> ${index}
	echo "" >> ${index}
	echo "${BLOGTITLE}" >> ${index}
	find ${BLOGDIR}/*.md -print0 | xargs -0 ls -t | while read f; do
		if [ "${f}" = ${index} ]; then
			continue
		fi
		base=${f%.md}
		bd="${BLOGDIR}/"
		echo "* [${base#${bd}}](${base#${SRCDIR}}.html)" >> ${index}
	done
	echo "indexed blog"
}

dev() {
	set +e
	httpwatcher --root ${DESTDIR} --port 8000 --no-browser &
	trap 'kill ${!}; exit 1' INT QUIT TERM
	while sleep 0.1; do
		if [ "${blogArg}" = true ]; then
			cmd="${0} -bl"
		else
			cmd="${0} -b"
		fi
		find ${SRCDIR} ${STATICDIR} ${TEMPLATE} | entr -dp ${cmd}
	done
}

configPathErr() {
	echo "config error: ${conf}"
	echo "invalid path: ${1}"
	exit 1;
}

usageMsg() {
	echo "usage: ssg [-bld]"
	echo "help: man ssg"
	exit 1
}

set -eu
conf="${PWD}/ssg.conf"
if [ -f ${conf} ]; then
	. ${conf}
else
	echo "missing: ${conf}"
	echo ""
	usageMsg
fi
if [ $# -eq 0 ]; then
	usageMsg
fi
while getopts ":bld" arg; do
	case "${arg}" in
		b)
			buildArg=true
			;;
		l)
			blogArg=true
			;;
		d)
			devArg=true
			;;
		*)
			usageMsg
			;;
	esac
done
if [ "${blogArg}" = true ]; then
	blog
fi
if [ "${buildArg}" = true ]; then
	build
fi
if [ "${devArg}" = true ]; then
	dev
fi