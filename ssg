#!/bin/sh

SRCDIR=""
DESTDIR=""
STATICDIR=""
TEMPLATE=""

build() {
	rm -rf ${DESTDIR}/
	mkdir ${DESTDIR}/
	for f in $(find ${SRCDIR}/ -type f,l); do
		if [ "${f}" = ${TEMPLATE} ]; then
			continue
		fi
		path=${f#${SRCDIR}}
		base=${path%.*}
		out="${DESTDIR}${base}.html"
		mkdir -p $(dirname ${out})
		pandoc \
			-standalone \
			--template=${TEMPLATE} \
			--to=html \
			${f} > ${out}
	done
	cp -a ${STATICDIR}/. ${DESTDIR}/
	echo "build complete"
}

noConfig() {
	echo "no config: ${conf}"
	echo "help: man ssg"
	exit 1
}

configPathErr() {
	echo "config error: ${conf}"
	echo "invalid path: ${1}"
	echo "help: man ssg"
	exit 1;
}

usageMsg() {
	echo "usage: ssg [-b]"
	echo "help: man ssg"
	exit 1
}

set -eu
conf="${PWD}/ssg.conf"
if [ -f ${conf} ]; then
	. ${conf}
else
	noConfig
fi
if [ $# -eq 0 ]; then
	usageMsg
fi
if [ ${1} = "-b" ]; then
	if [ ! -d ${SRCDIR} ]; then
		configPathErr ${SRCDIR}
	elif [ ! -d ${DESTDIR} ]; then
		configPathErr ${DESTDIR}
	elif [ ! -d ${STATICDIR} ]; then
		configPathErr ${STATICDIR}
	elif [ ! -f ${TEMPLATE} ]; then
		configPathErr ${TEMPLATE}
	fi
	build
else
	usageMsg
fi